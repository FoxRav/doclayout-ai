# === Parse engine ===================================================
# hybrid | vl | structurev3 | best | auto  (auto → hybrid)
PARSE_ENGINE=hybrid

# === Quality ========================================================
PARSE_QUALITY=max
PARSE_SPEED_PRIORITY=false

# === Hybrid pipeline roles ==========================================
PARSE_USE_VL_FOR_TEXT=true
PARSE_USE_VL_FOR_READING_ORDER=true
PARSE_USE_STRUCTUREV3_FOR_LAYOUT=true
PARSE_USE_STRUCTUREV3_FOR_IMAGES=true
PARSE_USE_STRUCTUREV3_FOR_PDF_GEOMETRY=true
PARSE_SAVE_ENGINE_COMPARISON=true
PARSE_NO_SILENT_FALLBACK=true
PARSE_PDF_MODE=structural
PARSE_EMIT_FACSIMILE=false
PARSE_EMIT_CLEAN=false
PARSE_EMIT_DEBUG_PDF=false
PARSE_EMIT_TEST_ARTIFACTS=false
PARSE_DEBUG_OUTPUT_DIR=ocr
PARSE_LAYOUT_PRESERVE=true
PARSE_REFLOW_TEXT=false
PARSE_FACSIMILE_VISIBLE_OCR=false
PARSE_FACSIMILE_INVISIBLE_TEXT=true
PARSE_FACSIMILE_DRAW_DEBUG=false
PARSE_FACSIMILE_DRAW_BBOX=false

# === Engine toggles =================================================
PARSE_VL_ENABLED=true
PARSE_STRUCTUREV3_ENABLED=true

# === OCR device =====================================================
PARSE_OCR_DEVICE=auto

# === Multilingual OCR ================================================
PARSE_OCR_PRIMARY_LANGUAGE=fi
PARSE_OCR_EXTRA_LANGUAGES=sv,en,de,fr,es,it,nl,pl,pt,ru
PARSE_OCR_LANGUAGE_MODE=auto

# === PaddleOCR-VL ====================================================
PARSE_VL_PIPELINE_VERSION=v1.6
PARSE_VL_DEVICE=auto
PARSE_VL_SAVE_RAW=true
PARSE_VL_FALLBACK_ON_ERROR=true
PARSE_OCR_VL_CONFIDENCE_THRESHOLD=0.6

# === Output format ===================================================
PARSE_DEFAULT_OUTPUT_MODE=auto
PARSE_WRITE_PDF=true
